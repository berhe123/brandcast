# Brandcast — backend environment
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-name.vercel.app

# ─── Auth ───────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string

# Google Identity Services (OAuth 2.0 Web client)
# Client ID is required for the official Google button (ends with .apps.googleusercontent.com).
# Client secret stays on the server only — never commit real secrets to git.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sign-in is passwordless: email Continue or Google — no OTP codes.

# ─── AI Providers ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
