# VibePost — backend environment
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-name.vercel.app

# ─── Auth ───────────────────────────────────────────────────────────────────
# Secret used to sign login tokens (JWT). Use a long random string in production.
JWT_SECRET=change-me-to-a-long-random-string
# Optional: enable real Google sign-in (otherwise the Google button runs in demo mode).
GOOGLE_CLIENT_ID=
# Optional: configure an email provider to actually send login codes (otherwise
# the 6-digit code is shown on screen in demo mode). Add ONE of these keys.
RESEND_API_KEY=          # https://resend.com/api-keys
SENDGRID_API_KEY=        # https://app.sendgrid.com/settings/api_keys
# The "from" address shown on the sign-in email. Must be a verified sender/domain
# on your provider. Resend's shared sandbox sender works for quick tests.
EMAIL_FROM=VibePost <onboarding@resend.dev>

# ─── AI Providers ───────────────────────────────────────────────────────────
# The AI Model Router uses every provider you supply a key for. Any provider
# left blank runs in realistic DEMO (mock) mode — the app works fully without
# keys, then upgrades to live models the moment you add them.
ANTHROPIC_API_KEY=your_anthropic_api_key_here   # https://console.anthropic.com/
OPENAI_API_KEY=your_openai_api_key_here         # https://platform.openai.com/api-keys
GEMINI_API_KEY=your_gemini_api_key_here         # https://aistudio.google.com/apikey
DEEPSEEK_API_KEY=your_deepseek_api_key_here     # https://platform.deepseek.com/
